# Ignore files that are not needed in the Docker build context
.git
.gitignore
Dockerfile
.dockerignore
README.md
LICENSE
# Ignore local development files
*.swp
*.swo
# Ignore build artifacts
argo-values
# Ignore IDE files
.idea/
.vscode/
